# =============================================================================
# .env — environment variables consumed by docker-compose.yml
# =============================================================================
# This file is auto-generated by `make configure` from config.toml.
# You generally don't need to edit it directly — edit config.toml instead.
#
# This example shows every variable docker-compose.yml expects, so you have
# a fallback if you'd rather skip the auto-config flow.
# =============================================================================

# General
TIMEZONE=America/Argentina/Buenos_Aires
DATA_LOCATION=/path/to/your/media

# =============================================================================
# VPN (Gluetun)
# Full provider list: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
# =============================================================================
VPN_SERVICE_PROVIDER=protonvpn
SERVER_COUNTRIES=Argentina
VPN_TYPE=openvpn

# OpenVPN (ProtonVPN, NordVPN, Surfshark, etc.)
OPENVPN_USER=
OPENVPN_PASSWORD=

# WireGuard (Mullvad, custom) — leave empty if using OpenVPN
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# =============================================================================
# Service credentials
# =============================================================================
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=

# Prograrr — bearer token for the exposed service.
# `configure.sh` auto-generates one if left empty.
PROGRARR_API_KEY=

# =============================================================================
# Immich (photo library)
# =============================================================================
IMMICH_VERSION=release
IMMICH_UPLOAD_LOCATION=/path/to/your/media/immich
IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich
IMMICH_DB_PASSWORD=

# =============================================================================
# API keys (populated after services start, by `make configure`)
# =============================================================================
SONARR_API_KEY=
SONARR_ANIME_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
JELLYFIN_API_KEY=
JELLYSEERR_API_KEY=
SABNZBD_API_KEY=
