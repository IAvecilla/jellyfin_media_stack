# =============================================================================
# Secrets — never commit
# =============================================================================
.env
config.toml
homepage/.env
immich/.env
recyclarr/secrets.yml

# =============================================================================
# Service runtime state — fully ignored. Configs are rebuilt by configure.sh
# from config.toml on every machine.
# =============================================================================
sonarr/
sonarr-anime/
radarr/
prowlarr/
lidarr/
bazarr/
bazarr-anime/
sabnzbd/
gluetun/
jellyseerr/
jellyfin-config/
jellyfin-cache/
organizr/

# =============================================================================
# Bazarr — keep only the custom Subdivx provider
# =============================================================================
!bazarr/
bazarr/*
!bazarr/custom/
bazarr/custom/__pycache__/

# =============================================================================
# qBittorrent — runtime state, regenerated by configure.sh
# =============================================================================
qbittorrent/

# =============================================================================
# Recyclarr — keep recyclarr.yml + settings.yml, ignore the rest
# =============================================================================
!recyclarr/
recyclarr/*
!recyclarr/recyclarr.yml
!recyclarr/settings.yml

# =============================================================================
# Homepage — keep yaml configs, ignore logs and the auto-generated .env
# =============================================================================
homepage/logs/

# =============================================================================
# Immich — runtime state (postgres data, model cache)
# =============================================================================
immich/postgres/
immich/model-cache/

# =============================================================================
# General patterns
# =============================================================================
*.log
*.log.*
*.log.gz
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.pid
